{
  "name": "selfhosted-sandpack-editor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "npm run build:files && vite",
    "build:files": "node build-files.mjs",
    "build": "npm run build:files && npm run build:bundler && tsc -b && vite build",
    "build:bundler": "node build-bundler.mjs",
    "preview": "npm run build:files && npm run build:bundler && vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codesandbox/sandpack-react": "^2.19.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.11.2"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1062.0",
    "@aws-sdk/lib-storage": "^3.1062.0",
    "@eslint/js": "^9.39.4",
    "@msgpack/msgpack": "^3.1.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^6.0.0"
  }
}
